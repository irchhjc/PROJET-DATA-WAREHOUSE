# ===============================================
# Configuration de connexion PostgreSQL
# Copier ce fichier en `.env` et adapter les valeurs
# ===============================================

# Base source (Sakila / Pagila)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=changeme
PG_DB_SOURCE=sakila

# Base data warehouse cible
PG_DB_DWH=sakila_dwh

# Configuration ETL
ETL_BATCH_SIZE=5000
ETL_LATE_FEE_PER_DAY=1.00     # USD par jour de retard
ETL_GRACE_DAYS=0              # nombre de jours de tolérance avant pénalité

# Configuration Dashboard
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=True
